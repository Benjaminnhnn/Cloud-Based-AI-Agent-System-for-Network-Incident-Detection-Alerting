# ======================================
# Deployment Environment Template
# ======================================
# Copy this file to .env.staging or .env.production
# Update values with your actual credentials
# DO NOT commit .env files to git

# ======================================
# Docker Image Registry
# ======================================
# GitHub Container Registry owner/org
# Example: github-username or org-name
GHCR_OWNER=your-github-username-or-org

# Image tag (optional - can be overridden by deploy script)
# Examples: staging-latest, v1.0.0, production-abc123
IMAGE_TAG=staging-latest

# ======================================
# AI Agent Configuration
# ======================================
# Google Generative AI API key
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram integration (optional)
# Leave empty or remove if not using Telegram notifications
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Port for AI Agent (default 8000)
AI_AGENT_PORT=8000

# Public HTTPS URL for Telegram webhook registration.
# Leave empty if you only use outbound Telegram notifications.
# Example: https://aiops.example.com
AI_AGENT_PUBLIC_URL=

# ======================================
# Payment API Configuration
# ======================================
# Database connection string
# Format: postgresql://username:password@host:port/database
# Example: postgresql://aiops_user:secure_pass@db-host:5432/aiops_db
DATABASE_URL=postgresql://aiops_user:aiops_pass@localhost:5432/aiops_db

# Secret key for Payment API
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change_me_to_a_strong_random_key

# Environment identifier (staging or production)
ENVIRONMENT=staging
