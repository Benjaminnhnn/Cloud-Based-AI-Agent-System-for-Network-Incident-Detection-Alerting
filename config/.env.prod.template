# ==============================================
# AI Agent Environment Configuration (Production)
# ==============================================
# Copy this file to .env.prod on monitor-ai-01
# Update values with your actual credentials

# ==================== GEMINI API ====================
# Get from: https://aistudio.google.com/app/apikeys
GEMINI_API_KEY=your_gemini_api_key_here

# ==================== TELEGRAM BOT ====================
# Get from: @BotFather on Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Your chat ID where alerts will be sent
# Get from: @userinfobot on Telegram
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ==================== ALERTMANAGER ====================
# Internal connection to Prometheus AlertManager
# (on same network, no need to change)
ALERTMANAGER_URL=http://alertmanager:9093

# ==================== PROMETHEUS ====================
PROMETHEUS_URL=http://prometheus:9090

# ==================== LOGGING ====================
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1

# ==================== DEBUG MODE ====================
DEBUG=false
