{
  "description": "🔧 Multi-Service Monitoring Configuration - Ansible Managed",
  "version": "1.0",
  "managed_by": "Ansible",
  "region": "{{ aws_region | default('ap-southeast-1') }}",
  "environment": "{{ deployment_environment | default('production') }}",
  
  "services": {
    "nginx": {
      "enabled": {{ services.nginx.enabled | default(true) | lower }},
      "type": "web-server",
      "port": {{ services.nginx.port | default(80) }},
      "severity": "{{ services.nginx.severity | default('CRITICAL') }}",
      "description": "Nginx web server",
      "check_interval": 5,
      "timeout": 3,
      "alert_cooldown": 60,
      "retry_attempts": 2,
      "monitoring": {
        "health_check": true,
        "log_monitoring": true,
        "metrics": ["response_time", "error_rate", "uptime"]
      }
    },
    
    "postgresql": {
      "enabled": {{ services.postgresql.enabled | default(true) | lower }},
      "type": "database",
      "port": {{ services.postgresql.port | default(5432) }},
      "severity": "{{ services.postgresql.severity | default('CRITICAL') }}",
      "description": "PostgreSQL database server",
      "check_interval": 5,
      "timeout": 3,
      "alert_cooldown": 60,
      "retry_attempts": 2,
      "monitoring": {
        "health_check": true,
        "log_monitoring": true,
        "metrics": ["connection_count", "qps", "replication_lag"]
      }
    },
    
    "redis": {
      "enabled": {{ services.redis.enabled | default(true) | lower }},
      "type": "cache",
      "port": {{ services.redis.port | default(6379) }},
      "severity": "{{ services.redis.severity | default('HIGH') }}",
      "description": "Redis cache service",
      "check_interval": 10,
      "timeout": 2,
      "alert_cooldown": 90,
      "retry_attempts": 1,
      "monitoring": {
        "health_check": true,
        "log_monitoring": false,
        "metrics": ["memory_usage", "evictions", "uptime"]
      }
    },
    
    "docker": {
      "enabled": {{ services.docker.enabled | default(true) | lower }},
      "type": "container-engine",
      "port": null,
      "severity": "{{ services.docker.severity | default('HIGH') }}",
      "description": "Docker container runtime",
      "check_interval": 15,
      "timeout": 5,
      "alert_cooldown": 120,
      "retry_attempts": 2,
      "monitoring": {
        "health_check": true,
        "log_monitoring": true,
        "metrics": ["container_count", "memory_usage", "disk_usage"]
      }
    },
    
    "system": {
      "enabled": true,
      "type": "infrastructure",
      "port": null,
      "severity": "CRITICAL",
      "description": "System-level metrics (CPU, RAM, Disk)",
      "check_interval": 15,
      "timeout": 3,
      "alert_cooldown": 60,
      "retry_attempts": 1,
      "monitoring": {
        "health_check": true,
        "log_monitoring": true,
        "metrics": ["cpu_usage", "memory_usage", "disk_usage", "network_io"]
      }
    }
  },
  
  "monitoring": {
    "enabled": true,
    "check_interval": {{ monitoring_check_interval | default(5) }},
    "batch_size": 10,
    "alert_cooldown": {{ alert_cooldown | default(60) }},
    "max_queue_size": 1000,
    "queue_drain_interval": 5,
    "max_retries": 3,
    "timeout_threshold": 5
  },
  
  "thresholds": {
    "cpu_usage_percent": {
      "warning": {{ cpu_warning_threshold | default(75) }},
      "critical": {{ cpu_critical_threshold | default(85) }},
      "evaluation_duration": 120
    },
    "memory_usage_percent": {
      "warning": {{ memory_warning_threshold | default(80) }},
      "critical": {{ memory_critical_threshold | default(90) }},
      "evaluation_duration": 60
    },
    "disk_usage_percent": {
      "warning": {{ disk_warning_threshold | default(75) }},
      "critical": {{ disk_critical_threshold | default(85) }},
      "evaluation_duration": 300
    },
    "network_error_rate": {
      "warning": 0.01,
      "critical": 0.05,
      "evaluation_duration": 300
    },
    "response_time_ms": {
      "warning": 500,
      "critical": 1000,
      "evaluation_duration": 60
    }
  },
  
  "alert_channels": {
    "webhook": {
      "enabled": true,
      "url": "{{ webhook_url | default('http://localhost:8000/webhook') }}",
      "method": "POST",
      "timeout": 5,
      "retry": 3
    },
    "telegram": {
      "enabled": {{ telegram_enabled | default(true) | lower }},
      "bot_token": "{{ telegram_bot_token | default('') }}",
      "chat_id": "{{ telegram_chat_id | default('') }}"
    },
    "email": {
      "enabled": false,
      "smtp_server": "localhost",
      "smtp_port": 25,
      "from_address": "monitor@example.com"
    }
  },
  
  "recovery_actions": {
    "nginx_restart": {
      "enabled": true,
      "condition": "service_down",
      "action": "systemctl restart nginx",
      "cooldown": 300,
      "max_attempts": 3
    },
    "postgresql_restart": {
      "enabled": true,
      "condition": "service_down",
      "action": "systemctl restart postgresql",
      "cooldown": 600,
      "max_attempts": 1
    },
    "docker_restart": {
      "enabled": true,
      "condition": "daemon_error",
      "action": "systemctl restart docker",
      "cooldown": 600,
      "max_attempts": 1
    }
  },
  
  "logging": {
    "level": "{{ log_level | default('INFO') }}",
    "format": "[%(asctime)s] [%(levelname)s] %(message)s",
    "file": "{{ log_file | default('/var/log/ai-agent/service-monitor.log') }}",
    "max_size_mb": 100,
    "backup_count": 10
  },
  
  "prometheus": {
    "enabled": true,
    "url": "{{ prometheus_url | default('http://localhost:9090') }}",
    "scrape_interval": 15,
    "evaluation_interval": 15,
    "alert_manager_url": "{{ alertmanager_url | default('http://localhost:9093') }}"
  }
}
