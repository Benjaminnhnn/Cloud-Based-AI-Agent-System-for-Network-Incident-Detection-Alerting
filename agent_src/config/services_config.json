{
  "description": "🔧 Multi-Service Monitoring Configuration",
  "version": "1.0",
  "region": "ap-southeast-1",
  "environment": "production",
  
  "services": {
    "nginx": {
      "enabled": false,
      "type": "web-server",
      "port": 80,
      "severity": "CRITICAL",
      "description": "Nginx web server",
      "check_interval": 5,
      "timeout": 3,
      "alert_cooldown": 60,
      "retry_attempts": 2,
      "monitoring": {
        "health_check": true,
        "log_monitoring": true,
        "metrics": ["response_time", "error_rate", "uptime"]
      }
    },
    
    "postgresql": {
      "enabled": false,
      "type": "database",
      "port": 5432,
      "severity": "CRITICAL",
      "description": "PostgreSQL database server",
      "check_interval": 5,
      "timeout": 3,
      "alert_cooldown": 60,
      "retry_attempts": 2,
      "monitoring": {
        "health_check": true,
        "log_monitoring": true,
        "metrics": ["connection_count", "qps", "replication_lag"]
      }
    },
    
    "redis": {
      "enabled": false,
      "type": "cache",
      "port": 6379,
      "severity": "HIGH",
      "description": "Redis cache service",
      "check_interval": 10,
      "timeout": 2,
      "alert_cooldown": 90,
      "retry_attempts": 1,
      "monitoring": {
        "health_check": true,
        "log_monitoring": false,
        "metrics": ["memory_usage", "evictions", "uptime"]
      }
    },
    
    "docker": {
      "enabled": false,
      "type": "container-engine",
      "port": null,
      "severity": "HIGH",
      "description": "Docker container runtime",
      "check_interval": 15,
      "timeout": 5,
      "alert_cooldown": 120,
      "retry_attempts": 2,
      "monitoring": {
        "health_check": true,
        "log_monitoring": true,
        "metrics": ["container_count", "memory_usage", "disk_usage"]
      }
    },
    
    "system": {
      "enabled": false,
      "type": "infrastructure",
      "port": null,
      "severity": "CRITICAL",
      "description": "System-level metrics (CPU, RAM, Disk)",
      "check_interval": 15,
      "timeout": 3,
      "alert_cooldown": 60,
      "retry_attempts": 1,
      "monitoring": {
        "health_check": true,
        "log_monitoring": true,
        "metrics": ["cpu_usage", "memory_usage", "disk_usage", "network_io"]
      }
    }
  },
  
  "monitoring": {
    "enabled": true,
    "check_interval": 5,
    "batch_size": 10,
    "alert_cooldown": 60,
    "max_queue_size": 1000,
    "queue_drain_interval": 5,
    "max_retries": 3,
    "timeout_threshold": 5
  },
  
  "thresholds": {
    "cpu_usage_percent": {
      "warning": 75,
      "critical": 85,
      "evaluation_duration": 120
    },
    "memory_usage_percent": {
      "warning": 80,
      "critical": 90,
      "evaluation_duration": 60
    },
    "disk_usage_percent": {
      "warning": 75,
      "critical": 85,
      "evaluation_duration": 300
    },
    "network_error_rate": {
      "warning": 0.01,
      "critical": 0.05,
      "evaluation_duration": 300
    },
    "response_time_ms": {
      "warning": 500,
      "critical": 1000,
      "evaluation_duration": 60
    }
  },
  
  "alert_channels": {
    "webhook": {
      "enabled": false,
      "url": "http://localhost:8000/webhook",
      "method": "POST",
      "timeout": 5,
      "retry": 3
    },
    "telegram": {
      "enabled": false,
      "bot_token": "TELEGRAM_TOKEN",
      "chat_id": "TELEGRAM_CHAT_ID"
    },
    "email": {
      "enabled": false,
      "smtp_server": "localhost",
      "smtp_port": 25,
      "from_address": "monitor@example.com"
    }
  },
  
  "recovery_actions": {
    "nginx_restart": {
      "enabled": false,
      "condition": "service_down",
      "action": "systemctl restart nginx",
      "cooldown": 300,
      "max_attempts": 3
    },
    "postgresql_restart": {
      "enabled": false,
      "condition": "service_down",
      "action": "systemctl restart postgresql",
      "cooldown": 600,
      "max_attempts": 1
    },
    "docker_restart": {
      "enabled": false,
      "condition": "daemon_error",
      "action": "systemctl restart docker",
      "cooldown": 600,
      "max_attempts": 1
    }
  },
  
  "logging": {
    "level": "INFO",
    "format": "[%(asctime)s] [%(levelname)s] %(message)s",
    "file": "/var/log/ai-agent/service-monitor.log",
    "max_size_mb": 100,
    "backup_count": 10
  },
  
  "prometheus": {
    "enabled": true,
    "url": "http://localhost:9090",
    "scrape_interval": 15,
    "evaluation_interval": 15,
    "alert_manager_url": "http://localhost:9093"
  }
}
